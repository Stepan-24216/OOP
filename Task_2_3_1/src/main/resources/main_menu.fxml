<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="container" prefHeight="600.0"
           prefWidth="600.0" xmlns="http://javafx.com/javafx/17"
           fx:controller="org.example.view.MainMenuController">

    <Canvas fx:id="menuCanvas" height="600.0" width="600.0"/>

    <VBox alignment="CENTER" spacing="150">
        <HBox alignment="CENTER" spacing="10">
            <ComboBox fx:id="levelComboBox" prefWidth="260.0" promptText="Выберите уровень"
                      style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #ff0000; -fx-text-fill: white;"/>
            <Button text="ОБЗОР" onAction="#handleBrowseDirectory"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #333333; -fx-text-fill: white;"/>
        </HBox>
        <Button fx:id="startButton" text="НАЧАТЬ ИГРУ" onAction="#handleStartGame"
                style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-background-color: #ff0000; -fx-text-fill: white; -fx-padding: 15 30; -fx-background-radius: 10;"/>

        <Label fx:id="errorLabel"
               style="-fx-text-fill: white; -fx-background-color: rgba(0,0,0,0.5); -fx-padding: 8 14; -fx-background-radius: 8;"
               visible="false"/>
    </VBox>
</StackPane>